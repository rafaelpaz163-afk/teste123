{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend/src/server.ts",
      "routePrefix": "/api",
      "framework": "express"
    }
  },
  "crons": [
    {
      "path": "/api/cron?type=all",
      "schedule": "0 3 * * *"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
